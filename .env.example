# Copy this file to .env and fill in your values.
# .env is in .gitignore and will NOT be committed.

# vLLM server URL (OpenAI-compatible API)
VLLM_BASE_URL=http://localhost:9000/v1

# Model name as loaded by vLLM
VLLM_MODEL=Qwen/Qwen3.5-9B-Instruct

# SQLite database path (optional, defaults to dental.db in project root)
# DB_URL=sqlite:///dental.db
